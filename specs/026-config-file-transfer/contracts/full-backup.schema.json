{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config Backup Package",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "layout": {
      "$ref": "#/$defs/DashboardLayout"
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PlcConnectionProfile"
      }
    }
  },
  "required": ["version"],
  "oneOf": [
    { "required": ["layout"] },
    { "required": ["profiles"] }
  ],
  "$defs": {
    "DashboardLayout": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "canvasColor": { "type": ["integer", "null"] },
        "widgets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WidgetConfiguration"
          }
        },
        "isDarkThemeMigrated": { "type": "boolean" },
        "isKineticCockpitMigrated": { "type": "boolean" },
        "hapticFeedbackEnabled": { "type": "boolean" }
      },
      "required": ["name", "widgets"]
    },
    "WidgetConfiguration": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["BUTTON", "SLIDER", "GAUGE"] },
        "column": { "type": "integer", "minimum": 0 },
        "row": { "type": "integer", "minimum": 0 },
        "colSpan": { "type": "integer", "minimum": 1 },
        "rowSpan": { "type": "integer", "minimum": 1 },
        "tagAddress": { "type": "string", "minLength": 1 },
        "customLabel": { "type": ["string", "null"] },
        "backgroundColor": { "type": ["integer", "null"] },
        "textColor": { "type": ["integer", "null"] },
        "pressedFillColor": { "type": ["integer", "null"] },
        "labelFontSizeMultiplier": { "type": "number", "minimum": 0.1 },
        "metricFontSizeMultiplier": { "type": "number", "minimum": 0.1 },
        "units": { "type": ["string", "null"] },
        "interactionType": { "enum": ["MOMENTARY", "LATCHING", "INDICATOR"] },
        "isInverted": { "type": "boolean" }
      },
      "required": ["type", "tagAddress"]
    },
    "PlcConnectionProfile": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "ipAddress": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "protocol": { "enum": ["RAW_TCP", "MQTT", "MODBUS_TCP", "OPC_UA"] }
      },
      "required": ["name", "ipAddress", "port", "protocol"]
    }
  }
}
