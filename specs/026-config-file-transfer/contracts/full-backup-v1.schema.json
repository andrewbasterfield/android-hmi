{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Full Backup Package (v1)",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1]
    },
    "layout": {
      "$ref": "#/definitions/DashboardLayout"
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PlcConnectionProfile"
      }
    }
  },
  "required": ["version", "layout", "profiles"],
  "definitions": {
    "DashboardLayout": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "widgets": { "type": "array" }
      },
      "required": ["name", "widgets"]
    },
    "PlcConnectionProfile": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ipAddress": { "type": "string" },
        "port": { "type": "integer" }
      },
      "required": ["name", "ipAddress", "port"]
    }
  }
}
